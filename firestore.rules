rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }

    match /users/{userId} {
      // Chaque cliente peut créer/lire/modifier son propre profil
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow read, update: if isSignedIn() && (request.auth.uid == userId || isAdmin());

      // Seul l'admin peut supprimer un utilisateur
      allow delete: if isAdmin();
    }

    match /reservations/{reservationId} {
      // Une cliente connectée peut créer une réservation pour elle-même
      allow create: if isSignedIn()
        && request.resource.data.clientUid == request.auth.uid;

      // La cliente lit ses réservations, l'admin lit tout
      allow read: if isSignedIn()
        && (
          resource.data.clientUid == request.auth.uid
          || isAdmin()
        );

      // Seul l'admin peut modifier les statuts et paiements
      allow update, delete: if isAdmin();
    }

    match /settings/{document=**} {
      // Tout utilisateur connecté peut lire les paramètres
      allow read: if isSignedIn();

      // Seul l'admin peut modifier prix, WhatsApp, horaires, etc.
      allow write: if isAdmin();
    }
  }
}